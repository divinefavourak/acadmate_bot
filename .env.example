# ─────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────────────────────
# Obtain from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# "polling" (dev) or "webhook" (production)
BOT_MODE=polling
# Required only when BOT_MODE=webhook. Must be HTTPS and publicly reachable.
WEBHOOK_DOMAIN=https://bot.example.com
WEBHOOK_PATH=/telegraf/secret-path
WEBHOOK_PORT=8443
# Optional secret token Telegram echoes back in X-Telegram-Bot-Api-Secret-Token
WEBHOOK_SECRET=change-me-long-random-string

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://acadmate:acadmate@localhost:5432/acadmate?schema=public
POSTGRES_USER=acadmate
POSTGRES_PASSWORD=acadmate
POSTGRES_DB=acadmate

# ─────────────────────────────────────────────────────────────
# Admin Dashboard API
# ─────────────────────────────────────────────────────────────
API_PORT=4000
# Use a long, random 256-bit secret in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
# Comma-separated list of allowed CORS origins for the dashboard front-end
CORS_ORIGINS=http://localhost:3000
# bcrypt cost factor
BCRYPT_ROUNDS=12

# Initial super-admin created by `npm run db:seed` (change before first run)
SEED_ADMIN_EMAIL=admin@acadmate.local
SEED_ADMIN_PASSWORD=ChangeMe!123

# ─────────────────────────────────────────────────────────────
# Moderation tunables (sane defaults; overridable per-chat in DB)
# ─────────────────────────────────────────────────────────────
FLOOD_MAX_MESSAGES=5
FLOOD_WINDOW_SECONDS=7
DUPLICATE_WINDOW_SECONDS=60
WARN_THRESHOLD=3
DEFAULT_MUTE_MINUTES=60

# ─────────────────────────────────────────────────────────────
# AI providers (free tiers). Configure one or more; the router
# tries them in the order listed in AI_PROVIDER_ORDER and fails
# over to the next when one is rate-limited. Leave a key blank to
# disable that provider. If NO keys are set, all AI features are
# silently disabled and the bot falls back to heuristic moderation.
# ─────────────────────────────────────────────────────────────
# Comma-separated priority order: groq,gemini
AI_PROVIDER_ORDER=groq,gemini

# Groq (https://console.groq.com/keys) — OpenAI-compatible, very fast
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# How long (seconds) to skip a provider after it returns 429
AI_PROVIDER_COOLDOWN_SECONDS=60
# Per-call timeout (ms) before giving up and trying the next provider
AI_REQUEST_TIMEOUT_MS=15000

# AI moderation: only classify messages that look risky (have links,
# are long, or mention many users) to conserve free-tier quota.
AI_MODERATION_ENABLED=true
AI_MODERATION_MIN_LENGTH=24

# ─────────────────────────────────────────────────────────────
# Operational alerts (optional)
# The bot DMs this Telegram user id when something errors. Find your
# id via @userinfobot. You must /start the bot in DM at least once,
# or Telegram won't let it message you. Leave blank to disable.
# ─────────────────────────────────────────────────────────────
OWNER_TELEGRAM_ID=
# Minimum seconds between alerts for the same error fingerprint
ERROR_ALERT_COOLDOWN_SECONDS=300
